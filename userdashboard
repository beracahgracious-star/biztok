<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Popshot · video feed</title>
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    }

    body {
      background: #0b0b10;
      color: #fff;
      height: 100vh;
      overflow: hidden;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    /* main container – full screen feed */
    .feed-container {
      position: relative;
      width: 100%;
      max-width: 420px;
      height: 100vh;
      max-height: 820px;
      background: #0f0f16;
      border-radius: 0;
      overflow: hidden;
      box-shadow: 0 0 60px rgba(255, 70, 120, 0.08);
      display: flex;
      flex-direction: column;
    }

    /* top bar – popshot branding */
    .top-bar {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      z-index: 20;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 1.2rem 0.6rem;
      background: linear-gradient(180deg, rgba(11, 11, 16, 0.8) 0%, transparent 100%);
      pointer-events: none;
    }

    .top-bar .brand {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 1.7rem;
      font-weight: 800;
      letter-spacing: -0.5px;
      color: white;
      text-shadow: 0 2px 12px rgba(0,0,0,0.6);
      pointer-events: auto;
    }

    .top-bar .brand i {
      background: linear-gradient(145deg, #ff3b6f, #ff8a5c);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      filter: drop-shadow(0 0 12px #ff3b6f55);
      font-size: 1.9rem;
    }

    .top-bar .brand span {
      background: linear-gradient(145deg, #ffffff, #d0d0f0);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .top-bar .actions {
      display: flex;
      gap: 1.2rem;
      pointer-events: auto;
      font-size: 1.3rem;
      color: #f0f0ff;
      text-shadow: 0 2px 10px rgba(0,0,0,0.5);
    }

    .top-bar .actions i {
      cursor: pointer;
      transition: 0.2s;
      opacity: 0.85;
    }

    .top-bar .actions i:hover {
      opacity: 1;
      transform: scale(1.05);
    }

    /* video scroll container */
    .video-scroll {
      flex: 1;
      overflow-y: scroll;
      scroll-snap-type: y mandatory;
      height: 100%;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      padding: 0;
      margin: 0;
    }

    .video-scroll::-webkit-scrollbar {
      display: none;
    }

    /* each video item – snap */
    .video-item {
      position: relative;
      width: 100%;
      height: 100vh;
      max-height: 820px;
      scroll-snap-align: start;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      background: #12121e;
      overflow: hidden;
    }

    /* video placeholder + gradient overlay */
    .video-placeholder {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: #1b1b2a;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 4rem;
      color: #3a3a5a;
    }

    .video-placeholder i {
      opacity: 0.3;
      filter: drop-shadow(0 0 30px #ff3b6f22);
    }

    .video-item .gradient-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 50%;
      background: linear-gradient(0deg, rgba(0,0,0,0.8) 0%, transparent 100%);
      pointer-events: none;
    }

    /* video info overlay (bottom) */
    .video-info {
      position: relative;
      z-index: 10;
      padding: 1.5rem 1.2rem 2rem;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      pointer-events: none;
    }

    .video-info .user {
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 600;
      font-size: 1.1rem;
      color: #fff;
      text-shadow: 0 2px 12px rgba(0,0,0,0.7);
    }

    .video-info .user i {
      font-size: 1.2rem;
      background: #2a2a44;
      padding: 6px;
      border-radius: 50%;
      border: 2px solid rgba(255,255,255,0.15);
    }

    .video-info .caption {
      font-size: 0.95rem;
      color: #e8e8ff;
      text-shadow: 0 2px 10px rgba(0,0,0,0.7);
      max-width: 80%;
      line-height: 1.4;
      font-weight: 400;
    }

    .video-info .caption i {
      margin-right: 8px;
      color: #ff5a7c;
    }

    /* right action buttons (like, comment, share) */
    .side-actions {
      position: absolute;
      right: 12px;
      bottom: 120px;
      z-index: 15;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 22px;
      pointer-events: auto;
    }

    .side-actions .action-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      color: #f0f0ff;
      text-shadow: 0 2px 12px rgba(0,0,0,0.7);
      cursor: pointer;
      transition: 0.2s;
      font-size: 1.7rem;
      gap: 2px;
    }

    .side-actions .action-btn span {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.3px;
      background: rgba(0,0,0,0.3);
      padding: 2px 6px;
      border-radius: 20px;
      backdrop-filter: blur(4px);
    }

    .side-actions .action-btn i {
      transition: 0.2s;
    }

    .side-actions .action-btn:hover i {
      transform: scale(1.15);
      color: #ff5a7c;
    }

    .side-actions .action-btn.liked i {
      color: #ff3b6f;
    }

    /* bottom nav (minimal) */
    .bottom-nav {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      background: rgba(11, 11, 16, 0.7);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-top: 1px solid rgba(255,255,255,0.04);
      display: flex;
      justify-content: space-around;
      padding: 0.7rem 0.5rem 1.2rem;
      z-index: 30;
    }

    .bottom-nav .nav-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      color: #8888aa;
      font-size: 0.6rem;
      transition: 0.2s;
      cursor: pointer;
      gap: 4px;
    }

    .bottom-nav .nav-item i {
      font-size: 1.5rem;
      transition: 0.2s;
    }

    .bottom-nav .nav-item.active {
      color: #ff5a7c;
    }

    .bottom-nav .nav-item.active i {
      transform: scale(1.05);
      text-shadow: 0 0 20px #ff3b6f55;
    }

    .bottom-nav .nav-item:hover {
      color: #e0e0ff;
    }

    /* indicator for scroll */
    .scroll-hint {
      position: absolute;
      bottom: 90px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 5;
      color: rgba(255,255,255,0.15);
      font-size: 1.4rem;
      animation: bounce 2s infinite;
      pointer-events: none;
    }

    @keyframes bounce {
      0%, 100% { transform: translateX(-50%) translateY(0); opacity: 0.3; }
      50% { transform: translateX(-50%) translateY(-8px); opacity: 0.8; }
    }

    /* responsive */
    @media (max-width: 460px) {
      .feed-container { max-height: 100vh; border-radius: 0; }
      .video-item { max-height: 100vh; }
      .video-info .caption { max-width: 70%; font-size: 0.9rem; }
      .side-actions { right: 8px; gap: 18px; }
      .side-actions .action-btn { font-size: 1.5rem; }
    }

    /* small demo avatars */
    .avatar-pic {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: #2a2a4a;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      color: #aaaae0;
      border: 2px solid rgba(255,255,255,0.08);
    }
  </style>
</head>
<body>

<div class="feed-container">
  <!-- top bar -->
  <div class="top-bar">
    <div class="brand">
      <i class="fas fa-bolt"></i>
      <span>popshot</span>
    </div>
    <div class="actions">
      <i class="fas fa-search"></i>
      <i class="fas fa-bell"></i>
    </div>
  </div>

  <!-- scrollable video feed -->
  <div class="video-scroll" id="videoScroll">
    <!-- video 1 -->
    <div class="video-item" data-index="0">
      <div class="video-placeholder">
        <i class="fas fa-play-circle"></i>
      </div>
      <div class="gradient-overlay"></div>

      <div class="video-info">
        <div class="user">
          <div class="avatar-pic"><i class="fas fa-user-astronaut"></i></div>
