        </div>
        <div class="caption">
          <i class="fas fa-music"></i> Sunset dreams · #vibes
        </div>
      </div>

      <div class="side-actions">
        <div class="action-btn" data-action="like">
          <i class="fas fa-heart"></i>
          <span>2.1k</span>
        </div>
        <div class="action-btn" data-action="comment">
          <i class="fas fa-comment"></i>
          <span>184</span>
        </div>
        <div class="action-btn" data-action="share">
          <i class="fas fa-share"></i>
          <span>56</span>
        </div>
      </div>
    </div>

    <!-- video 2 -->
    <div class="video-item" data-index="1">
      <div class="video-placeholder" style="background: #1e1e30;">
        <i class="fas fa-play-circle"></i>
      </div>
      <div class="gradient-overlay"></div>

      <div class="video-info">
        <div class="user">
          <div class="avatar-pic"><i class="fas fa-robot"></i></div>
          @neonpulse · <span style="font-weight:400; font-size:0.8rem; opacity:0.7;">5h ago</span>
        </div>
        <div class="caption">
          <i class="fas fa-bolt"></i> Cyberpunk city loop
        </div>
      </div>

      <div class="side-actions">
        <div class="action-btn" data-action="like">
          <i class="fas fa-heart"></i>
          <span>3.4k</span>
        </div>
        <div class="action-btn" data-action="comment">
          <i class="fas fa-comment"></i>
          <span>312</span>
        </div>
        <div class="action-btn" data-action="share">
          <i class="fas fa-share"></i>
          <span>89</span>
        </div>
      </div>
    </div>

    <!-- video 3 -->
    <div class="video-item" data-index="2">
      <div class="video-placeholder" style="background: #1a1a28;">
        <i class="fas fa-play-circle"></i>
      </div>
      <div class="gradient-overlay"></div>

      <div class="video-info">
        <div class="user">
          <div class="avatar-pic"><i class="fas fa-cat"></i></div>
          @pawtraits · <span style="font-weight:400; font-size:0.8rem; opacity:0.7;">8h ago</span>
        </div>
        <div class="caption">
          <i class="fas fa-paw"></i> Whiskers & chill 🐾
        </div>
      </div>

      <div class="side-actions">
        <div class="action-btn" data-action="like">
          <i class="fas fa-heart"></i>
          <span>5.7k</span>
        </div>
        <div class="action-btn" data-action="comment">
          <i class="fas fa-comment"></i>
          <span>421</span>
        </div>
        <div class="action-btn" data-action="share">
          <i class="fas fa-share"></i>
          <span>128</span>
        </div>
      </div>
    </div>

    <!-- video 4 -->
    <div class="video-item" data-index="3">
      <div class="video-placeholder" style="background: #16162a;">
        <i class="fas fa-play-circle"></i>
      </div>
      <div class="gradient-overlay"></div>

      <div class="video-info">
        <div class="user">
          <div class="avatar-pic"><i class="fas fa-dumbbell"></i></div>
          @ironminds · <span style="font-weight:400; font-size:0.8rem; opacity:0.7;">12h ago</span>
        </div>
        <div class="caption">
          <i class="fas fa-fire"></i> 5am grind · no excuses
        </div>
      </div>

      <div class="side-actions">
        <div class="action-btn" data-action="like">
          <i class="fas fa-heart"></i>
          <span>1.2k</span>
        </div>
        <div class="action-btn" data-action="comment">
          <i class="fas fa-comment"></i>
          <span>94</span>
        </div>
        <div class="action-btn" data-action="share">
          <i class="fas fa-share"></i>
          <span>33</span>
        </div>
      </div>
    </div>

    <!-- video 5 (extra) -->
    <div class="video-item" data-index="4">
      <div class="video-placeholder" style="background: #1c1c2e;">
        <i class="fas fa-play-circle"></i>
      </div>
      <div class="gradient-overlay"></div>

      <div class="video-info">
        <div class="user">
          <div class="avatar-pic"><i class="fas fa-moon"></i></div>
          @lunarphase · <span style="font-weight:400; font-size:0.8rem; opacity:0.7;">1d ago</span>
        </div>
        <div class="caption">
          <i class="fas fa-star"></i> Stargazing · cosmic vibes
        </div>
      </div>

      <div class="side-actions">
        <div class="action-btn" data-action="like">
          <i class="fas fa-heart"></i>
          <span>8.9k</span>
        </div>
        <div class="action-btn" data-action="comment">
          <i class="fas fa-comment"></i>
          <span>673</span>
        </div>
        <div class="action-btn" data-action="share">
          <i class="fas fa-share"></i>
          <span>210</span>
        </div>
      </div>
    </div>
  </div>

  <!-- scroll hint (down arrow) -->
  <div class="scroll-hint">
    <i class="fas fa-chevron-down"></i>
  </div>

  <!-- bottom navigation -->
  <div class="bottom-nav">
    <div class="nav-item active"><i class="fas fa-home"></i><span>Home</span></div>
    <div class="nav-item"><i class="fas fa-compass"></i><span>Explore</span></div>
    <div class="nav-item"><i class="fas fa-plus-circle"></i><span>Create</span></div>
    <div class="nav-item"><i class="fas fa-inbox"></i><span>Inbox</span></div>
    <div class="nav-item"><i class="fas fa-user"></i><span>Profile</span></div>
  </div>
</div>

<script>
  (function() {
    "use strict";

    // ----- like button toggle (demo) -----
    const likeBtns = document.querySelectorAll('.action-btn[data-action="like"]');
    likeBtns.forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        const icon = this.querySelector('i');
        const span = this.querySelector('span');
        // toggle like state
        if (this.classList.contains('liked')) {
          this.classList.remove('liked');
          icon.style.color = '#f0f0ff';
          // decrease count by 1 (if >0)
          let count = parseInt(span.innerText.replace(/,/g, ''), 10);
          if (count > 0) count--;
          span.innerText = count >= 1000 ? (count/1000).toFixed(1)+'k' : count;
        } else {
          this.classList.add('liked');
          icon.style.color = '#ff3b6f';
          let count = parseInt(span.innerText.replace(/,/g, ''), 10);
          count++;
          span.innerText = count >= 1000 ? (count/1000).toFixed(1)+'k' : count;
        }
      });
    });

    // ----- comment & share demo alert -----
    document.querySelectorAll('.action-btn[data-action="comment"], .action-btn[data-action="share"]').forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        const action = this.dataset.action;
        if (action === 'comment') {
          alert('💬 Comments would open here (demo)');
        } else if (action === 'share') {
          alert('🔗 Share link copied (demo)');
        }
      });
    });

    // ----- bottom nav demo highlight -----
    const navItems = document.querySelectorAll('.bottom-nav .nav-item');
    navItems.forEach(item => {
      item.addEventListener('click', function() {
        navItems.forEach(i => i.classList.remove('active'));
        this.classList.add('active');
        // optional feedback
        const label = this.querySelector('span')?.innerText || 'tab';
        alert('📍 ' + label + ' (demo navigation)');
      });
    });

    // ----- top bar icons demo -----
    document.querySelector('.top-bar .actions .fa-search')?.addEventListener('click', function() {
      alert('🔍 Search (demo)');
    });
    document.querySelector('.top-bar .actions .fa-bell')?.addEventListener('click', function() {
      alert('🔔 Notifications (demo)');
    });

    // ----- scroll hint disappear after scroll -----
    const scrollContainer = document.getElementById('videoScroll');
    const hint = document.querySelector('.scroll-hint');
    if (scrollContainer && hint) {
      scrollContainer.addEventListener('scroll', function() {
        if (this.scrollTop > 30) {
          hint.style.opacity = '0';
          hint.style.transition = 'opacity 0.4s';
        } else {
          hint.style.opacity = '1';
        }
      });
    }

    // ----- (optional) auto play / pause on visibility? not needed for demo -----
    console.log('Popshot feed ready · scroll to view videos');
  })();
</script>

</body>
</html>
