<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>Popshot · Algorithm Reader</title>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background: #0b0b10;
            color: #fff;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 1rem;
        }

        .algorithm-container {
            width: 100%;
            max-width: 500px;
            background: rgba(16, 16, 28, 0.85);
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            border-radius: 48px;
            padding: 2rem 1.8rem 2rem;
            border: 1px solid rgba(255, 70, 120, 0.15);
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.7), 0 0 40px rgba(255, 70, 120, 0.03);
            max-height: 95vh;
            overflow-y: auto;
        }

        .algorithm-container::-webkit-scrollbar {
            display: none;
        }

        .header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.8rem;
        }

        .header .back-btn {
            color: #b0b0d4;
            font-size: 1.3rem;
            cursor: pointer;
            transition: 0.2s;
            padding: 4px;
        }

        .header .back-btn:hover {
            color: #fff;
            transform: scale(1.05);
        }

        .header .brand {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 1.4rem;
            font-weight: 800;
            letter-spacing: -0.5px;
        }

        .header .brand i {
            background: linear-gradient(145deg, #ff3b6f, #ff8a5c);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            filter: drop-shadow(0 0 12px #ff3b6f55);
            font-size: 1.6rem;
        }

        .header .brand span {
            background: linear-gradient(145deg, #ffffff, #d0d0f0);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .status-badge {
            background: rgba(255, 59, 111, 0.08);
            border: 1px solid rgba(255, 59, 111, 0.1);
            border-radius: 30px;
            padding: 0.3rem 1rem;
            font-size: 0.7rem;
            font-weight: 600;
            color: #ff5a7c;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .status-badge .dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #66d9a0;
            display: inline-block;
            animation: pulse 1.5s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }

        .algorithm-intro {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 20px;
            padding: 1rem 1.2rem;
            margin-bottom: 1.5rem;
        }

        .algorithm-intro .title {
            font-weight: 700;
            font-size: 0.9rem;
            color: #e0e0ff;
            margin-bottom: 4px;
        }

        .algorithm-intro .desc {
            font-size: 0.8rem;
            color: #8a8ab0;
            line-height: 1.5;
        }

        .algorithm-intro .desc i {
            color: #ff5a7c;
            margin-right: 4px;
        }

        /* upload area for testing */
        .test-area {
            background: rgba(255, 255, 255, 0.02);
            border: 2px dashed rgba(255, 255, 255, 0.06);
            border-radius: 30px;
            padding: 1.5rem;
            text-align: center;
            cursor: pointer;
            transition: 0.25s;
            margin-bottom: 1.5rem;
        }

        .test-area:hover {
            border-color: rgba(255, 59, 111, 0.2);
            background: rgba(255, 255, 255, 0.04);
        }

        .test-area i {
            font-size: 2.5rem;
            color: #3a3a5a;
            margin-bottom: 6px;
        }

        .test-area .label {
            font-size: 0.9rem;
            color: #b0b0d4;
        }

        .test-area .sub {
            font-size: 0.75rem;
            color: #6a6a92;
            margin-top: 4px;
        }

        #testFileInput {
            display: none;
        }

        /* background scanner status */
        .scanner-status {
            background: rgba(0, 230, 118, 0.04);
            border: 1px solid rgba(0, 230, 118, 0.08);
            border-radius: 20px;
            padding: 0.8rem 1.2rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .scanner-status .icon {
            color: #66d9a0;
            font-size: 1.2rem;
        }

        .scanner-status .info {
            flex: 1;
        }

        .scanner-status .info .title {
            font-size: 0.85rem;
            font-weight: 600;
            color: #e0e0ff;
        }

        .scanner-status .info .sub {
            font-size: 0.75rem;
            color: #6a6a92;
        }

        .scanner-status .badge {
            font-size: 0.7rem;
            color: #66d9a0;
            font-weight: 600;
            background: rgba(0, 230, 118, 0.08);
            padding: 4px 12px;
            border-radius: 30px;
            border: 1px solid rgba(0, 230, 118, 0.1);
        }

        /* results */
        .results-section {
            margin-top: 1rem;
        }

        .result-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 20px;
            padding: 1rem 1.2rem;
            margin-bottom: 0.8rem;
            transition: 0.2s;
            animation: slideIn 0.4s ease;
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .result-card .result-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 6px;
        }

        .result-card .result-title {
            font-size: 0.85rem;
            font-weight: 600;
            color: #d0d0f0;
        }

        .result-card .result-title i {
            margin-right: 8px;
            color: #ff5a7c;
        }

        .result-card .result-status {
            font-size: 0.75rem;
            font-weight: 700;
            padding: 2px 12px;
            border-radius: 30px;
            text-transform: uppercase;
        }

        .result-card .result-status.pass {
            background: rgba(0, 230, 118, 0.12);
            border: 1px solid rgba(0, 230, 118, 0.15);
            color: #66d9a0;
        }

        .result-card .result-status.fail {
            background: rgba(255, 59, 111, 0.12);
            border: 1px solid rgba(255, 59, 111, 0.15);
            color: #ff5a7c;
        }

        .result-card .result-status.warning {
            background: rgba(255, 165, 0, 0.12);
            border: 1px solid rgba(255, 165, 0, 0.15);
            color: #ffa500;
        }

        .result-card .result-detail {
            font-size: 0.8rem;
            color: #8a8ab0;
            margin-top: 4px;
            line-height: 1.5;
        }

        .result-card .result-detail i {
            margin-right: 6px;
            font-size: 0.7rem;
        }

        .result-card .result-detail .highlight {
            color: #ff5a7c;
            font-weight: 600;
        }

        .result-card .result-detail .boost {
            color: #66d9a0;
            font-weight: 600;
        }

        .score-bar {
            margin-top: 8px;
            background: rgba(255, 255, 255, 0.04);
            border-radius: 30px;
            height: 6px;
            overflow: hidden;
        }

        .score-bar .fill {
            height: 100%;
            border-radius: 30px;
            transition: width 0.8s ease;
            background: linear-gradient(90deg, #ff3b6f, #ff6b4a);
            width: 0%;
        }

        .result-card .score-label {
            display: flex;
            justify-content: space-between;
            font-size: 0.7rem;
            color: #6a6a92;
            margin-top: 4px;
        }

        /* action buttons */
        .action-row {
            display: flex;
            gap: 10px;
            margin-top: 1rem;
        }

        .btn-secondary {
            flex: 1;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 30px;
            padding: 12px;
            color: #b0b0d4;
            font-weight: 600;
            font-size: 0.85rem;
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.06);
            border-color: rgba(255, 255, 255, 0.1);
            color: #fff;
        }

        .btn-secondary.primary {
            background: rgba(255, 59, 111, 0.12);
            border-color: rgba(255, 59, 111, 0.15);
            color: #ff5a7c;
        }

        .btn-secondary.primary:hover {
            background: rgba(255, 59, 111, 0.2);
            border-color: rgba(255, 59, 111, 0.3);
        }

        .btn-secondary:disabled {
            opacity: 0.3;
            cursor: not-allowed;
        }

        /* bottom nav */
        .bottom-nav {
            margin-top: 1.5rem;
            padding-top: 1rem;
            border-top: 1px solid rgba(255, 255, 255, 0.04);
            display: flex;
            justify-content: space-around;
        }

        .bottom-nav .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            color: #8888aa;
            font-size: 0.55rem;
            transition: 0.2s;
            cursor: pointer;
            gap: 2px;
        }

        .bottom-nav .nav-item i {
            font-size: 1.3rem;
            transition: 0.2s;
        }

        .bottom-nav .nav-item.active {
            color: #ff5a7c;
        }

        .bottom-nav .nav-item:hover {
            color: #e0e0ff;
        }

        .message-box {
            padding: 0.8rem 1rem;
            border-radius: 30px;
            font-size: 0.9rem;
            font-weight: 500;
            margin-bottom: 1rem;
            display: none;
        }

        .message-box.error {
            display: block;
            background: rgba(255, 59, 111, 0.12);
            border: 1px solid rgba(255, 59, 111, 0.2);
            color: #ff7a9c;
        }

        .message-box.success {
            display: block;
            background: rgba(0, 230, 118, 0.08);
            border: 1px solid rgba(0, 230, 118, 0.15);
            color: #66d9a0;
        }

        .message-box.info {
            display: block;
            background: rgba(45, 156, 219, 0.08);
            border: 1px solid rgba(45, 156, 219, 0.1);
            color: #66d9f0;
        }

        .empty-state {
            text-align: center;
            padding: 2rem 1rem;
            color: #5a5a82;
        }

        .empty-state i {
            font-size: 3rem;
            color: #2a2a4a;
            margin-bottom: 0.8rem;
        }

        @media (max-width: 460px) {
            .algorithm-container {
                padding: 1.5rem 1.2rem;
                border-radius: 28px;
            }
            .result-card {
                padding: 0.8rem 1rem;
            }
            .action-row {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>

<div class="algorithm-container">
    <!-- header -->
    <div class="header">
        <div class="brand">
            <i class="fas fa-bolt"></i>
            <span>algorithm</span>
        </div>
        <div class="back-btn" id="backBtn">
            <i class="fas fa-arrow-left"></i>
        </div>
    </div>

    <!-- status -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
        <div class="status-badge">
            <span class="dot"></span> Algorithm active
        </div>
        <span style="font-size: 0.7rem; color: #5a5a82;"><i class="fas fa-microchip"></i> v2.1.0 · background</span>
    </div>

    <!-- background scanner status -->
    <div class="scanner-status" id="scannerStatus">
        <div class="icon"><i class="fas fa-sync-alt fa-spin"></i></div>
        <div class="info">
            <div class="title">Background scanner active</div>
            <div class="sub" id="scannerSub">Monitoring content in real-time</div>
        </div>
        <div class="badge" id="scanCount">0 scans</div>
    </div>

    <!-- intro -->
    <div class="algorithm-intro">
        <div class="title"><i class="fas fa-robot" style="color:#ff5a7c;"></i> Algorithm Reader</div>
        <div class="desc">
            <i class="fas fa-check-circle" style="color:#66d9a0;"></i> Detects CapCut features & boosts views<br>
            <i class="fas fa-check-circle" style="color:#66d9a0;"></i> Identifies Popshot Stories & promotes<br>
            <i class="fas fa-times-circle" style="color:#ff5a7c;"></i> Blocks harmful / inappropriate content<br>
            <i class="fas fa-check-circle" style="color:#66d9a0;"></i> Validates sound compatibility
        </div>
    </div>

    <!-- upload test -->
    <div class="test-area" id="testArea">
        <i class="fas fa-upload"></i>
        <div class="label">Upload a video to test the algorithm</div>
        <div class="sub">MP4, MOV · max 100MB</div>
        <div id="testFileName" style="margin-top:8px; font-size:0.85rem; color:#ff5a7c;"></div>
    </div>
    <input type="file" id="testFileInput" accept="video/*">

    <!-- message -->
    <div id="messageBox" class="message-box"></div>

    <!-- results -->
    <div class="results-section" id="resultsSection">
        <div class="empty-state" id="emptyState">
            <i class="fas fa-microchip"></i>
            <div style="font-size:1rem; font-weight:600; color:#8a8ab0;">No analysis yet</div>
            <div style="font-size:0.85rem; color:#5a5a82;">Upload a video or wait for background scans</div>
        </div>
        <div id="resultsContainer" style="display:none;"></div>
    </div>

    <!-- action buttons -->
    <div class="action-row">
        <button class="btn-secondary" id="clearBtn"><i class="fas fa-undo"></i> Reset</button>
        <button class="btn-secondary primary" id="simulateBtn"><i class="fas fa-play"></i> Simulate upload</button>
    </div>

    <!-- bottom nav -->
    <div class="bottom-nav">
        <div class="nav-item"><i class="fas fa-home"></i><span>Home</span></div>
        <div class="nav-item"><i class="fas fa-compass"></i><span>Explore</span></div>
        <div class="nav-item"><i class="fas fa-plus-circle"></i><span>Create</span></div>
        <div class="nav-item active"><i class="fas fa-microchip"></i><span>Algorithm</span></div>
        <div class="nav-item"><i class="fas fa-user"></i><span>Profile</span></div>
    </div>
</div>

<script>
    (function() {
        "use strict";

        // ----- profanity / blocklist -----
        const BLOCKLIST = [
            'graphic', 'gore', 'violence', 'blood', 'kill', 'murder', 'death',
            'porn', 'sex', 'nude', 'naked', 'erotic', 'xxx', 'fuck', 'shit',
            'hate', 'racist', 'slur', 'discrimination', 'harass', 'bully',
            'drug', 'weed', 'cocaine', 'heroin', 'meth', 'alcohol', 'drunk',
            'gamble', 'casino', 'bet', 'lottery', 'terror', 'bomb', 'attack',
            'uncivil', 'rude', 'abuse', 'toxic', 'offensive', 'inappropriate',
            'pornography', 'graphic content', 'bad content', 'uncouth'
        ];

        // ----- CapCut feature keywords -----
        const CAPCUT_FEATURES = [
            'capcut', 'auto cut', 'auto captions', 'transitions', 'effects',
            'filters', 'overlay', 'chroma key', 'green screen', 'speed ramp',
            'smooth', 'glitch', 'transition', 'zoom', 'pan', 'motion blur',
            'lens flare', 'color grade', 'lut', 'text overlay', 'sticker',
            'animation', 'keyframe', 'mask', 'blend mode', 'audio duck'
        ];

        // ----- Sound fit keywords -----
        const SOUND_FIT_KEYWORDS = [
            'music', 'beat', 'rhythm', 'melody', 'instrumental', 'vocal',
            'acoustic', 'electronic', 'hip hop', 'pop', 'rock', 'jazz',
            'classical', 'ambient', 'soundtrack', 'podcast', 'voiceover',
            'sfx', 'sound effect', 'nature', 'city', 'atmosphere'
        ];

        // ----- Mock content descriptions for background scanning -----
        const MOCK_DESCRIPTIONS = [
            'Check out my new travel vlog using CapCut transitions! #travel #story',
            'Food review with auto captions from CapCut. #foodie',
            'Gaming montage with smooth transitions and effects. #gaming #story',
            'Music video with glitch effects and speed ramping. #music',
            'Fashion lookbook with color grading and overlays. #fashion',
            'Nature timelapse with motion blur and zoom effects. #nature',
            'Comedy sketch with text overlays and animations. #comedy #story',
            'Tech review with green screen and chroma key. #tech',
            'Art timelapse with lens flare and blend modes. #art',
            'Workout video with audio ducking and filters. #fitness',
            'Beautiful sunset with ambient music and smooth transitions.',
            'This video contains graphic violence and explicit content.',
            'Pornographic material not suitable for Popshot.',
            'Hate speech and discriminatory content detected.',
            'Drug use and uncivil behaviour shown here.'
        ];

        // ----- DOM refs -----
        const testArea = document.getElementById('testArea');
        const testFileInput = document.getElementById('testFileInput');
        const testFileName = document.getElementById('testFileName');
        const resultsContainer = document.getElementById('resultsContainer');
        const emptyState = document.getElementById('emptyState');
        const messageBox = document.getElementById('messageBox');
        const clearBtn = document.getElementById('clearBtn');
        const simulateBtn = document.getElementById('simulateBtn');
        const backBtn = document.getElementById('backBtn');
        const scanCount = document.getElementById('scanCount');
        const scannerSub = document.getElementById('scannerSub');

        let scanCounter = 0;
        let backgroundInterval = null;
        let isBackgroundRunning = true;

        // ----- Helper: show message -----
        function showMessage(msg, type = 'error') {
            messageBox.textContent = msg;
            messageBox.className = 'message-box ' + type;
            clearTimeout(window.msgTimeout);
            window.msgTimeout = setTimeout(() => {
                messageBox.className = 'message-box';
                messageBox.textContent = '';
            }, 4000);
        }

        // ----- Helper: check if text contains any blocked content -----
        function containsBlockedContent(text) {
            if (!text) return false;
            const lower = text.toLowerCase();
            return BLOCKLIST.some(word => lower.includes(word));
        }

        // ----- Helper: detect CapCut features -----
        function detectCapCutFeatures(text) {
            if (!text) return [];
            const lower = text.toLowerCase();
            const detected = [];
            CAPCUT_FEATURES.forEach(feature => {
                if (lower.includes(feature.toLowerCase())) {
                    detected.push(feature);
                }
            });
            return detected;
        }

        // ----- Helper: detect Popshot Story -----
        function isPopshotStory(text) {
            if (!text) return false;
            const lower = text.toLowerCase();
            return lower.includes('story') || lower.includes('popshot story') || lower.includes('#story');
        }

        // ----- Helper: check if sound is fit -----
        function isSoundFit(text) {
            if (!text) return false;
            const lower = text.toLowerCase();
            return SOUND_FIT_KEYWORDS.some(keyword => lower.includes(keyword.toLowerCase()));
        }

        // ----- Algorithm analysis -----
        function analyzeVideo(fileName, fileType, customDesc = null) {
            const metadata = {
                fileName: fileName || 'video_2024.mp4',
                fileSize: Math.floor(Math.random() * 80) + 10,
                duration: Math.floor(Math.random() * 58) + 2,
                resolution: Math.random() > 0.5 ? '1080p' : '720p',
                hasAudio: Math.random() > 0.2,
                frameRate: Math.random() > 0.3 ? '30fps' : '60fps',
            };

            const contentTypes = ['travel', 'music', 'food', 'sports', 'tech', 'fashion', 'gaming', 'art', 'comedy', 'education'];
            const primaryContent = contentTypes[Math.floor(Math.random() * contentTypes.length)];
            const secondaryContent = contentTypes[Math.floor(Math.random() * contentTypes.length)];

            let description = customDesc || MOCK_DESCRIPTIONS[Math.floor(Math.random() * MOCK_DESCRIPTIONS.length)];

            const hasHarmfulContent = containsBlockedContent(description);
            const capcutFeatures = detectCapCutFeatures(description);
            const isStory = isPopshotStory(description);
            const soundFit = isSoundFit(description) || metadata.hasAudio;
            const isApproved = !hasHarmfulContent && soundFit;

            let boostScore = 0;
            if (isApproved) {
                boostScore += 20;
                if (capcutFeatures.length > 0) boostScore += 30;
                if (isStory) boostScore += 25;
                if (soundFit) boostScore += 15;
                if (metadata.resolution === '1080p') boostScore += 5;
                if (metadata.frameRate === '60fps') boostScore += 5;
                boostScore = Math.min(boostScore, 100);
            }

            return {
                fileName: metadata.fileName,
                fileSize: metadata.fileSize,
                duration: metadata.duration,
                resolution: metadata.resolution,
                hasAudio: metadata.hasAudio,
                frameRate: metadata.frameRate,
                content: {
                    primary: primaryContent,
                    secondary: secondaryContent,
                    description: description
                },
                checks: {
                    harmfulContent: hasHarmfulContent,
                    capcutFeatures: capcutFeatures,
                    isStory: isStory,
                    soundFit: soundFit,
                    isApproved: isApproved
                },
                boostScore: boostScore,
                timestamp: new Date().toLocaleString()
            };
        }

        // ----- Render results -----
        function renderResults(analysis, isBackground = false) {
            emptyState.style.display = 'none';
            resultsContainer.style.display = 'block';

            const isApproved = analysis.checks.isApproved;
            const hasHarmful = analysis.checks.harmfulContent;
            const capcutCount = analysis.checks.capcutFeatures.length;
            const isStory = analysis.checks.isStory;
            const soundFit = analysis.checks.soundFit;
            const score = analysis.boostScore;

            const statusClass = isApproved ? 'pass' : 'fail';
            const statusText = isApproved ? 'APPROVED ✅' : 'REJECTED ❌';
            const bgLabel = isBackground ? '🔍 Background scan' : '📤 Manual upload';

            let html = `
                <div class="result-card" style="border-color: ${isApproved ? 'rgba(0,230,118,0.15)' : 'rgba(255,59,111,0.2)'};">
                    <div class="result-header">
                        <div class="result-title"><i class="fas fa-video"></i> ${analysis.fileName}</div>
                        <div class="result-status ${statusClass}">${statusText}</div>
                    </div>
                    <div class="result-detail">
                        <i class="fas fa-clock"></i> ${analysis.duration}s · ${analysis.resolution} · ${analysis.frameRate}
                        <span style="margin:0 6px;">·</span>
                        <i class="fas fa-hashtag"></i> #${analysis.content.primary} #${analysis.content.secondary}
                        <span style="margin-left: 10px; font-size:0.7rem; color:#5a5a82;">${bgLabel}</span>
                    </div>
                    <div class="score-bar">
                        <div class="fill" style="width: ${score}%; background: ${score > 70 ? 'linear-gradient(90deg, #66d9a0, #00e676)' : score > 40 ? 'linear-gradient(90deg, #ffa500, #ffb300)' : 'linear-gradient(90deg, #ff5a7c, #ff1744)'};"></div>
                    </div>
                    <div class="score-label">
                        <span>Boost score: <strong style="color:${score > 70 ? '#66d9a0' : score > 40 ? '#ffa500' : '#ff5a7c'};">${score}%</strong></span>
                        <span>${score > 70 ? '🚀 High visibility' : score > 40 ? '📈 Moderate reach' : '📉 Limited reach'}</span>
                    </div>
                </div>
            `;

            html += `<div class="result-card">`;
            html += `<div class="result-header"><div class="result-title"><i class="fas fa-search"></i> Analysis Details</div></div>`;

            html += `<div class="result-detail" style="margin-bottom:6px;">`;
            html += hasHarmful ? `<i class="fas fa-times-circle" style="color:#ff5a7c;"></i> <span class="highlight">Harmful content detected</span> — video disapproved` :
                `<i class="fas fa-check-circle" style="color:#66d9a0;"></i> Content is safe and appropriate`;
            html += `</div>`;

            html += `<div class="result-detail" style="margin-bottom:6px;">`;
            if (capcutCount > 0) {
                html += `<i class="fas fa-check-circle" style="color:#66d9a0;"></i> <span class="boost">${capcutCount} CapCut feature${capcutCount > 1 ? 's' : ''} detected</span> — <span style="color:#b0b0d4;">${analysis.checks.capcutFeatures.join(', ')}</span>`;
                html += `<br><span style="font-size:0.7rem; color:#5a5a82; margin-left:20px;"><i class="fas fa-arrow-up"></i> Boost applied for CapCut content</span>`;
            } else {
                html += `<i class="fas fa-info-circle" style="color:#6a6a92;"></i> No CapCut features detected`;
            }
            html += `</div>`;

            html += `<div class="result-detail" style="margin-bottom:6px;">`;
            if (isStory) {
                html += `<i class="fas fa-check-circle" style="color:#66d9a0;"></i> <span class="boost">Popshot Story detected</span> — <span style="color:#b0b0d4;">content will be promoted</span>`;
                html += `<br><span style="font-size:0.7rem; color:#5a5a82; margin-left:20px;"><i class="fas fa-arrow-up"></i> Boost applied for Story content</span>`;
            } else {
                html += `<i class="fas fa-info-circle" style="color:#6a6a92;"></i> Not a Popshot Story (use #story)`;
            }
            html += `</div>`;

            html += `<div class="result-detail" style="margin-bottom:6px;">`;
            if (soundFit) {
                html += `<i class="fas fa-check-circle" style="color:#66d9a0;"></i> <span class="boost">Sound is suitable</span> — audio meets quality standards`;
            } else if (analysis.hasAudio) {
                html += `<i class="fas fa-exclamation-circle" style="color:#ffa500;"></i> <span style="color:#ffa500;">Sound quality needs improvement</span> — may affect reach`;
            } else {
                html += `<i class="fas fa-times-circle" style="color:#ff5a7c;"></i> <span class="highlight">No audio detected</span> — sound is required for approval`;
            }
            html += `</div>`;

            html += `<div class="result-detail" style="font-size:0.7rem; color:#5a5a82; margin-top:4px; border-top:1px solid rgba(255,255,255,0.04); padding-top:6px;">`;
            html += `<i class="fas fa-microchip"></i> Analyzed: ${analysis.timestamp} · File size: ${analysis.fileSize}MB`;
            html += `</div>`;
            html += `</div>`;

            html += `
                <div class="result-card" style="border-color: ${isApproved ? 'rgba(0,230,118,0.08)' : 'rgba(255,59,111,0.08)'};">
                    <div class="result-header">
                        <div class="result-title"><i class="fas fa-robot"></i> Algorithm Decision</div>
                    </div>
                    <div class="result-detail">
                        ${isApproved ? 
                            `<i class="fas fa-check-circle" style="color:#66d9a0;"></i> <span class="boost">Video approved for publication</span> — ${score > 70 ? 'High boost applied for maximum visibility' : 'Moderate boost applied'}` :
                            `<i class="fas fa-times-circle" style="color:#ff5a7c;"></i> <span class="highlight">Video rejected</span> — ${hasHarmful ? 'Contains harmful/inappropriate content' : !soundFit ? 'Sound does not meet quality standards' : 'Does not meet content guidelines'}`
                        }
                    </div>
                    <div class="result-detail" style="margin-top:4px; font-size:0.8rem; color:#8a8ab0;">
                        <i class="fas fa-lightbulb"></i> ${isApproved ? '✅ Eligible for Explore and For You pages' : '❌ Not eligible for promotion'}
                    </div>
                </div>
            `;

            resultsContainer.innerHTML = html + resultsContainer.innerHTML;
            // Keep only last 10 results
            const cards = resultsContainer.querySelectorAll('.result-card');
            if (cards.length > 30) {
                for (let i = 30; i < cards.length; i++) {
                    cards[i].remove();
                }
            }
        }

        // ----- Background scanner -----
        function backgroundScan() {
            if (!isBackgroundRunning) return;

            scanCounter++;
            scanCount.textContent = `${scanCounter} scans`;

            // Generate random content
            const names = ['travel_vlog.mp4', 'music_video.mp4', 'gaming_montage.mp4', 'food_review.mp4', 'fashion_lookbook.mp4', 'sports_highlights.mp4', 'art_timelapse.mp4', 'comedy_sketch.mp4', 'tech_review.mp4', 'nature_scene.mp4'];
            const fakeName = names[Math.floor(Math.random() * names.length)];
            const analysis = analyzeVideo(fakeName, 'video/mp4');

            renderResults(analysis, true);

            const randomStatus = ['🔍 Scanning content...', '📊 Analyzing features...', '🎵 Checking audio...', '📝 Reviewing metadata...', '⚡ Processing algorithm...'];
            scannerSub.textContent = randomStatus[Math.floor(Math.random() * randomStatus.length)];

            // Show occasional status updates
            if (scanCounter % 3 === 0) {
                const randomMsg = [
                    '✅ Safe content detected and boosted',
                    '⚠️ Content flagged for review',
                    '🚀 High-quality content promoted',
                    '📉 Low quality content deprioritized'
                ];
                showMessage(randomMsg[Math.floor(Math.random() * randomMsg.length)], 'info');
                setTimeout(() => {
                    if (messageBox.className.includes('info')) {
                        messageBox.className = 'message-box';
                        messageBox.textContent = '';
                    }
                }, 3000);
            }
        }

        // ----- Process manual file upload -----
        function processFile(file) {
            if (!file) {
                showMessage('⚠️ Please select a video file.', 'error');
                return;
            }

            if (!file.type.startsWith('video/')) {
                showMessage('⚠️ Please select a video file.', 'error');
                return;
            }

            if (file.size > 100 * 1024 * 1024) {
                showMessage('⚠️ File too large. Max 100MB.', 'error');
                return;
            }

            testFileName.textContent = `📹 ${file.name} (${(file.size / 1024 / 1024).toFixed(1)} MB)`;

            // Run algorithm
            const analysis = analyzeVideo(file.name, file.type);
            renderResults(analysis, false);
            showMessage('✅ Algorithm analysis complete!', 'success');
            setTimeout(() => {
                if (messageBox.className.includes('success')) {
                    messageBox.className = 'message-box';
                    messageBox.textContent = '';
                }
            }, 3000);
        }

        // ----- Event listeners -----
        testArea.addEventListener('click', () => testFileInput.click());

        testFileInput.addEventListener('change', function() {
            if (this.files && this.files[0]) {
                processFile(this.files[0]);
            }
        });

        clearBtn.addEventListener('click', function() {
            testFileName.textContent = '';
            testFileInput.value = '';
            resultsContainer.innerHTML = '';
            resultsContainer.style.display = 'none';
            emptyState.style.display = 'block';
            messageBox.className = 'message-box';
            messageBox.textContent = '';
            // Reset scan counter
            scanCounter = 0;
            scanCount.textContent = '0 scans';
            showMessage('🔄 Reset complete', 'success');
            setTimeout(() => {
                if (messageBox.className.includes('success')) {
                    messageBox.className = 'message-box';
                    messageBox.textContent = '';
                }
            }, 1500);
        });

        simulateBtn.addEventListener('click', function() {
            const names = ['travel_vlog.mp4', 'music_video.mp4', 'gaming_montage.mp4', 'food_review.mp4', 'fashion_lookbook.mp4', 'sports_highlights.mp4', 'art_timelapse.mp4', 'comedy_sketch.mp4', 'tech_review.mp4', 'nature_scene.mp4'];
            const fakeName = names[Math.floor(Math.random() * names.length)];
            const analysis = analyzeVideo(fakeName, 'video/mp4');
            renderResults(analysis, false);
            testFileName.textContent = `📹 ${fakeName} (simulated)`;
            showMessage('🧪 Simulated analysis complete', 'success');
            setTimeout(() => {
                if (messageBox.className.includes('success')) {
                    messageBox.className = 'message-box';
                    messageBox.textContent = '';
                }
            }, 3000);
        });

        backBtn.addEventListener('click', function() {
            alert('🔙 Go back (demo)');
        });

        document.querySelectorAll('.bottom-nav .nav-item').forEach(item => {
            item.addEventListener('click', function() {
                document.querySelectorAll('.bottom-nav .nav-item').forEach(i => i.classList.remove('active'));
                this.classList.add('active');
                const label = this.querySelector('span')?.innerText || 'tab';
                alert(`📍 ${label} (demo navigation)`);
            });
        });

        // ----- Start background scanner -----
        function startBackgroundScanner() {
            isBackgroundRunning = true;
            // Run immediately, then every 4-8 seconds
            backgroundScan();
            backgroundInterval = setInterval(() => {
                backgroundScan();
            }, Math.floor(Math.random() * 4000) + 4000);
        }

        startBackgroundScanner();

        // Clean up on page unload
        window.addEventListener('beforeunload', function() {
            if (backgroundInterval) {
                clearInterval(backgroundInterval);
            }
        });

        console.log('Popshot Algorithm Reader · Running in background');
    })();
</script>

</body>
</html>
