<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
  <title>Popshot · Sign up · 18+</title>
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    }

    body {
      min-height: 100vh;
      background: #0b0b10;
      background-image: radial-gradient(circle at 30% 20%, #1a1a2e 0%, #0b0b10 80%);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      margin: 0;
    }

    /* main card – glassmorphism with neon glow */
    .popshot-card {
      max-width: 460px;
      width: 100%;
      background: rgba(16, 16, 28, 0.8);
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      border-radius: 48px;
      padding: 2rem 1.8rem 2.2rem;
      border: 1px solid rgba(255, 70, 120, 0.2);
      box-shadow: 0 30px 60px rgba(0, 0, 0, 0.7), 0 0 0 1px rgba(255, 70, 120, 0.08) inset, 0 0 40px rgba(255, 70, 120, 0.05);
      transition: all 0.25s ease;
    }

    /* Brand header */
    .brand {
      text-align: center;
      margin-bottom: 1.8rem;
    }

    .brand .logo {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 2.6rem;
      font-weight: 800;
      letter-spacing: -1px;
      color: #fff;
      text-shadow: 0 0 30px rgba(255, 70, 120, 0.3);
    }

    .brand .logo i {
      background: linear-gradient(145deg, #ff3b6f, #ff8a5c);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      font-size: 2.8rem;
      filter: drop-shadow(0 0 16px #ff3b6f55);
    }

    .brand .logo span {
      background: linear-gradient(145deg, #ffffff, #d0d0f0);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .brand .tagline {
      color: #9a9abf;
      font-size: 0.9rem;
      letter-spacing: 1px;
      margin-top: 4px;
      font-weight: 400;
      opacity: 0.8;
    }

    /* 18+ badge */
    .age-badge {
      display: inline-block;
      background: rgba(255, 59, 111, 0.15);
      border: 1px solid rgba(255, 59, 111, 0.25);
      border-radius: 60px;
      padding: 0.3rem 1.2rem;
      font-size: 0.7rem;
      font-weight: 700;
      color: #ff5a7c;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      margin-top: 6px;
      backdrop-filter: blur(4px);
    }

    /* form */
    .auth-form {
      display: block;
    }

    .form-group {
      margin-bottom: 1.2rem;
    }

    .form-group label {
      display: block;
      font-size: 0.75rem;
      font-weight: 600;
      color: #b0b0d4;
      margin-bottom: 5px;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }

    .form-group label i {
      margin-right: 8px;
      color: #ff5a7c;
      width: 18px;
    }

    .input-wrapper {
      display: flex;
      align-items: center;
      background: rgba(255, 255, 255, 0.04);
      border: 1.5px solid rgba(255, 255, 255, 0.06);
      border-radius: 30px;
      padding: 0 18px;
      transition: all 0.2s;
      backdrop-filter: blur(4px);
      position: relative;
    }

    .input-wrapper:focus-within {
      border-color: #ff3b6f;
      box-shadow: 0 0 0 4px rgba(255, 59, 111, 0.12), 0 0 20px rgba(255, 59, 111, 0.03);
      background: rgba(255, 255, 255, 0.06);
    }

    .input-wrapper i {
      color: #7070a0;
      font-size: 1rem;
      width: 24px;
      text-align: center;
      transition: 0.2s;
    }

    .input-wrapper:focus-within i {
      color: #ff5a7c;
    }

    .input-wrapper input {
      width: 100%;
      border: none;
      background: transparent;
      padding: 15px 10px;
      font-size: 1rem;
      outline: none;
      color: #f0f0ff;
      font-weight: 500;
    }

    .input-wrapper input::placeholder {
      color: #6a6a92;
      font-weight: 400;
      font-size: 0.9rem;
    }

    /* username availability indicator */
    .username-status {
      font-size: 0.75rem;
      margin-top: 6px;
      padding-left: 14px;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: all 0.2s;
    }

    .username-status.available {
      color: #66d9a0;
    }

    .username-status.taken {
      color: #ff5a7c;
    }

    .username-status.checking {
      color: #b0b0d4;
    }

    .username-status i {
      font-size: 0.8rem;
    }

    /* age verification row */
    .age-row {
      display: flex;
      gap: 12px;
      margin: 0.2rem 0 0.8rem;
    }

    .age-row .input-wrapper {
      flex: 1;
    }

    .age-row .input-wrapper input {
      text-align: center;
      font-weight: 600;
      padding: 14px 6px;
    }

    .age-row .input-wrapper input::placeholder {
      text-align: center;
      font-weight: 400;
    }

    /* terms & consent */
    .consent-group {
      margin: 1.5rem 0 1.8rem;
    }

    .consent-group label {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      color: #b0b0d4;
      font-size: 0.85rem;
      cursor: pointer;
      line-height: 1.5;
    }

    .consent-group label input[type="checkbox"] {
      accent-color: #ff3b6f;
      width: 20px;
      height: 20px;
      min-width: 20px;
      margin-top: 2px;
      border-radius: 6px;
      border: 1px solid #55557a;
      background: transparent;
      cursor: pointer;
    }

    .consent-group label a {
      color: #ff5a7c;
      text-decoration: none;
      font-weight: 500;
    }

    .consent-group label a:hover {
      text-decoration: underline;
    }

    /* primary button */
    .btn-primary {
      width: 100%;
      background: linear-gradient(145deg, #ff3b6f, #ff6b4a);
      border: none;
      padding: 17px;
      border-radius: 60px;
      font-weight: 700;
      font-size: 1.05rem;
      color: white;
      cursor: pointer;
      transition: 0.25s;
      box-shadow: 0 8px 28px rgba(255, 59, 111, 0.3);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      letter-spacing: 0.5px;
      text-shadow: 0 1px 4px rgba(0,0,0,0.2);
    }

    .btn-primary:hover {
      transform: scale(1.02);
      box-shadow: 0 12px 40px rgba(255, 59, 111, 0.45);
      background: linear-gradient(145deg, #ff2a5e, #ff5a3a);
    }

    .btn-primary:active {
      transform: scale(0.96);
    }

    .btn-primary i {
      font-size: 1.2rem;
    }

    .btn-primary:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
      box-shadow: 0 4px 16px rgba(255, 59, 111, 0.15);
    }

    /* divider & social */
    .divider {
      display: flex;
      align-items: center;
      gap: 16px;
      margin: 2rem 0 0.8rem;
      color: #5a5a82;
      font-size: 0.8rem;
      font-weight: 500;
    }

    .divider hr {
      flex: 1;
      border: none;
      border-top: 1.5px solid rgba(255, 255, 255, 0.05);
    }

    .social-login {
      display: flex;
      gap: 10px;
      justify-content: center;
      margin-top: 0.8rem;
    }

    .social-login button {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 40px;
      padding: 12px 14px;
      font-size: 0.9rem;
      font-weight: 600;
      color: #d0d0f0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      cursor: pointer;
      transition: 0.2s;
      flex: 1;
      backdrop-filter: blur(4px);
    }

    .social-login button i {
      font-size: 1.3rem;
    }

    .social-login button:hover {
      background: rgba(255, 255, 255, 0.08);
      border-color: rgba(255, 70, 120, 0.3);
      color: white;
    }

    /* footer link */
    .auth-footer {
      text-align: center;
      margin-top: 2rem;
      color: #8a8ab0;
      font-size: 0.9rem;
      border-top: 1px solid rgba(255, 255, 255, 0.04);
      padding-top: 1.5rem;
    }

    .auth-footer a {
      color: #ff5a7c;
      font-weight: 600;
      text-decoration: none;
      margin-left: 6px;
    }

    .auth-footer a:hover {
      text-decoration: underline;
    }

    /* error / success message */
    .message-box {
      padding: 0.8rem 1rem;
      border-radius: 30px;
      font-size: 0.9rem;
      font-weight: 500;
      margin-bottom: 1rem;
      display: none;
      backdrop-filter: blur(4px);
    }

    .message-box.error {
      display: block;
      background: rgba(255, 59, 111, 0.12);
      border: 1px solid rgba(255, 59, 111, 0.2);
      color: #ff7a9c;
    }

    .message-box.success {
      display: block;
      background: rgba(0, 230, 118, 0.08);
      border: 1px solid rgba(0, 230, 118, 0.15);
      color: #66d9a0;
    }

    /* responsive */
    @media (max-width: 460px) {
      .popshot-card { padding: 1.5rem 1.2rem 1.8rem; }
      .brand .logo { font-size: 2.2rem; }
      .age-row { gap: 8px; }
      .age-row .input-wrapper { flex: 1; }
      .social-login button { font-size: 0.8rem; padding: 10px 8px; }
    }
  </style>
</head>
<body>

<div class="popshot-card">
  <!-- Brand -->
  <div class="brand">
    <div class="logo">
      <i class="fas fa-bolt"></i>
      <span>popshot</span>
    </div>
    <div class="tagline">
      short · bold · viral
      <div class="age-badge"><i class="fas fa-shield-alt" style="margin-right: 6px;"></i> 18+ only</div>
    </div>
  </div>

  <!-- Signup form -->
  <div class="auth-form">
    <form id="signup-form" action="#" method="POST">
      <!-- message area -->
      <div id="form-message" class="message-box"></div>

      <!-- username -->
      <div class="form-group">
        <label for="signup-username"><i class="fas fa-user"></i> Username</label>
        <div class="input-wrapper">
          <i class="fas fa-at"></i>
          <input type="text" id="signup-username" placeholder="viral_creator" required autocomplete="off">
        </div>
        <div id="username-status" class="username-status">
          <i class="fas fa-circle"></i> <span id="status-text">Username available</span>
        </div>
      </div>

      <!-- email -->
      <div class="form-group">
        <label for="signup-email"><i class="fas fa-envelope"></i> Email</label>
        <div class="input-wrapper">
          <i class="fas fa-envelope"></i>
          <input type="email" id="signup-email" placeholder="you@popshot.com" required>
        </div>
      </div>

      <!-- password -->
      <div class="form-group">
        <label for="signup-password"><i class="fas fa-lock"></i> Password</label>
        <div class="input-wrapper">
          <i class="fas fa-key"></i>
          <input type="password" id="signup-password" placeholder="min 8 characters" required>
        </div>
      </div>

      <!-- confirm password -->
      <div class="form-group">
        <label for="signup-confirm"><i class="fas fa-check-circle"></i> Confirm password</label>
        <div class="input-wrapper">
          <i class="fas fa-shield-alt"></i>
          <input type="password" id="signup-confirm" placeholder="confirm password" required>
        </div>
      </div>

      <!-- AGE VERIFICATION – 18+ -->
      <div class="form-group" style="margin-bottom: 0.4rem;">
        <label><i class="fas fa-calendar-alt"></i> Date of birth · <span style="color:#ff5a7c; font-weight: 700;">must be 18+</span></label>
        <div class="age-row">
          <div class="input-wrapper">
            <i class="fas fa-calendar-day"></i>
            <input type="number" id="dob-day" placeholder="DD" min="1" max="31" required>
          </div>
          <div class="input-wrapper">
            <i class="fas fa-calendar-alt"></i>
            <input type="number" id="dob-month" placeholder="MM" min="1" max="12" required>
          </div>
          <div class="input-wrapper">
            <i class="fas fa-calendar"></i>
            <input type="number" id="dob-year" placeholder="YYYY" min="1900" max="2006" required>
          </div>
        </div>
        <div style="font-size: 0.7rem; color: #6a6a92; margin-top: 4px; padding-left: 12px;">
          <i class="fas fa-info-circle"></i> You must be 18 or older to join Popshot.
        </div>
      </div>

      <!-- consent + terms -->
      <div class="consent-group">
        <label>
          <input type="checkbox" id="terms-check" required>
          <span>I confirm I am <strong style="color:#ff5a7c;">18+</strong> and agree to the <a href="#">Terms of Service</a> &amp; <a href="#">Privacy Policy</a>.</span>
        </label>
      </div>

      <!-- submit -->
      <button type="submit" class="btn-primary" id="signup-btn">
        <i class="fas fa-user-plus"></i> Create account
      </button>

      <div class="divider"><hr> or <hr></div>
      <div class="social-login">
        <button type="button"><i class="fab fa-tiktok"></i> TikTok</button>
        <button type="button"><i class="fab fa-google"></i> Google</button>
        <button type="button"><i class="fab fa-apple"></i> Apple</button>
      </div>
    </form>

    <div class="auth-footer">
      Already on Popshot? <a href="#" id="go-to-login">Log in</a>
    </div>
  </div>
</div>

<script>
  (function() {
    "use strict";

    // ----- mock database of existing usernames (simulate uniqueness) -----
    const EXISTING_USERNAMES = [
      'viral_creator',
      'popstar',
      'neonpulse',
      'vibewave',
      'lunarphase',
      'ironminds',
      'pawtraits',
      'admin',
      'popshot',
      'tiktokfan',
      'shortsviral',
      'contentking',
      'trendsetter',
      'memequeen',
      'gamerlife'
    ];

    // DOM refs
    const form = document.getElementById('signup-form');
    const usernameInput = document.getElementById('signup-username');
    const email = document.getElementById('signup-email');
    const password = document.getElementById('signup-password');
    const confirmPass = document.getElementById('signup-confirm');
    const dayInput = document.getElementById('dob-day');
    const monthInput = document.getElementById('dob-month');
    const yearInput = document.getElementById('dob-year');
    const termsCheck = document.getElementById('terms-check');
    const messageBox = document.getElementById('form-message');
    const submitBtn = document.getElementById('signup-btn');
    const usernameStatus = document.getElementById('username-status');
    const statusText = document.getElementById('status-text');

    // username availability state
    let isUsernameAvailable = false;
    let isCheckingUsername = false;

    // helper: show message
    function showMessage(msg, type = 'error') {
      messageBox.textContent = msg;
      messageBox.className = 'message-box ' + type;
      clearTimeout(window.msgTimeout);
      window.msgTimeout = setTimeout(() => {
        messageBox.className = 'message-box';
        messageBox.textContent = '';
      }, 6000);
    }

    // age validation: returns true if 18+
    function isAgeValid(day, month, year) {
      if (!day || !month || !year) return false;
      const today = new Date();
      const birthDate = new Date(year, month - 1, day);
      if (isNaN(birthDate.getTime())) return false;
      let age = today.getFullYear() - birthDate.getFullYear();
      const m = today.getMonth() - birthDate.getMonth();
      if (m < 0 || (m === 0 && today.getDate() < birthDate.getDate())) {
        age--;
      }
      return age >= 18;
    }

    // check if username exists (case-insensitive)
    function isUsernameTaken(username) {
      if (!username) return false;
      const lower = username.toLowerCase().trim();
      return EXISTING_USERNAMES.some(existing => existing.toLowerCase() === lower);
    }

    // validate username format (alphanumeric + underscore, 3-20 chars)
    function isValidUsernameFormat(username) {
      if (!username) return false;
      const trimmed = username.trim();
      if (trimmed.length < 3 || trimmed.length > 20) return false;
      return /^[a-zA-Z0-9_]+$/.test(trimmed);
    }

    // update username status indicator
    function updateUsernameStatus(username) {
      const statusIcon = usernameStatus.querySelector('i');
      const trimmed = username.trim();

      // reset
      usernameStatus.className = 'username-status';

      if (!trimmed) {
        statusIcon.className = 'fas fa-circle';
        statusText.textContent = 'Enter a username';
        usernameStatus.className = 'username-status checking';
        isUsernameAvailable = false;
        return;
      }

      // check format
      if (!isValidUsernameFormat(trimmed)) {
        statusIcon.className = 'fas fa-times-circle';
        statusText.textContent = '3-20 chars, letters, numbers, underscore';
        usernameStatus.className = 'username-status taken';
        isUsernameAvailable = false;
        return;
      }

      // check availability
      if (isUsernameTaken(trimmed)) {
        statusIcon.className = 'fas fa-times-circle';
        statusText.textContent = 'Username already taken';
        usernameStatus.className = 'username-status taken';
        isUsernameAvailable = false;
      } else {
        statusIcon.className = 'fas fa-check-circle';
        statusText.textContent = 'Username available';
        usernameStatus.className = 'username-status available';
        isUsernameAvailable = true;
      }
    }

    // Real-time username check (debounced)
    let usernameTimeout = null;
    usernameInput.addEventListener('input', function() {
      clearTimeout(usernameTimeout);
      const val = this.value;
      
      // show checking state
      const statusIcon = usernameStatus.querySelector('i');
      statusIcon.className = 'fas fa-spinner fa-pulse';
      statusText.textContent = 'Checking...';
      usernameStatus.className = 'username-status checking';
      isUsernameAvailable = false;

      usernameTimeout = setTimeout(() => {
        updateUsernameStatus(val);
      }, 400);
    });

    // Also check on blur
    usernameInput.addEventListener('blur', function() {
      clearTimeout(usernameTimeout);
      updateUsernameStatus(this.value);
    });

    // Form submit
    form.addEventListener('submit', function(e) {
      e.preventDefault();

      // reset message
      messageBox.className = 'message-box';
      messageBox.textContent = '';

      // 1. required fields
      const uname = usernameInput.value.trim();
      const mail = email.value.trim();
      const pass = password.value.trim();
      const confirm = confirmPass.value.trim();
      const day = parseInt(dayInput.value.trim(), 10);
      const month = parseInt(monthInput.value.trim(), 10);
      const year = parseInt(yearInput.value.trim(), 10);

      if (!uname || !mail || !pass || !confirm || !day || !month || !year) {
        showMessage('⚠️ Please fill in all fields.', 'error');
        return;
      }

      // 2. username format validation
      if (!isValidUsernameFormat(uname)) {
        showMessage('⚠️ Username must be 3-20 characters (letters, numbers, underscore).', 'error');
        return;
      }

      // 3. username uniqueness (final check)
      if (isUsernameTaken(uname)) {
        showMessage('⚠️ Username "' + uname + '" is already taken. Please choose another.', 'error');
        return;
      }

      // 4. password length
      if (pass.length < 8) {
        showMessage('⚠️ Password must be at least 8 characters.', 'error');
        return;
      }

      // 5. password match
      if (pass !== confirm) {
        showMessage('⚠️ Passwords do not match.', 'error');
        return;
      }

      // 6. age verification (18+)
      if (!isAgeValid(day, month, year)) {
        showMessage('⛔ You must be 18 or older to join Popshot.', 'error');
        return;
      }

      // 7. terms checked
      if (!termsCheck.checked) {
        showMessage('⚠️ Please confirm you are 18+ and agree to the Terms.', 'error');
        return;
      }

      // 8. email format (simple)
      if (!mail.includes('@') || !mail.includes('.')) {
        showMessage('⚠️ Please enter a valid email address.', 'error');
        return;
      }

      // ----- success -----
      // Add the new username to the "database" so it can't be used again
      EXISTING_USERNAMES.push(uname);

      showMessage('🎉 Account created, ' + uname + '! Welcome to Popshot.', 'success');
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<i class="fas fa-spinner fa-pulse"></i> Creating...';
      
      setTimeout(() => {
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="fas fa-user-plus"></i> Create account';
        // reset form (optional)
        form.reset();
        // reset username status
        usernameStatus.className = 'username-status';
        const statusIcon = usernameStatus.querySelector('i');
        statusIcon.className = 'fas fa-circle';
        statusText.textContent = 'Enter a username';
        isUsernameAvailable = false;
        
        alert('✅ Demo signup complete! (redirect to feed would happen)');
        // window.location.href = 'feed.html'; // uncomment for real flow
      }, 1800);
    });

    // Social login demo
    document.querySelectorAll('.social-login button').forEach(btn => {
      btn.addEventListener('click', function() {
        const provider = this.innerText.trim();
        showMessage('🔐 ' + provider + ' sign-in demo (no backend)', 'error');
      });
    });

    // "Log in" link demo
    document.getElementById('go-to-login').addEventListener('click', function(e) {
      e.preventDefault();
      alert('🔁 Switch to login page (demo)');
      // window.location.href = 'login.html';
    });

    // Terms / Privacy links demo
    document.querySelectorAll('.consent-group a').forEach(link => {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        alert('📄 ' + this.innerText + ' page (demo)');
      });
    });

    // Age hint check
    function checkAgeHint() {
      const day = parseInt(dayInput.value.trim(), 10);
      const month = parseInt(monthInput.value.trim(), 10);
      const year = parseInt(yearInput.value.trim(), 10);
      if (day && month && year) {
        if (!isAgeValid(day, month, year)) {
          // subtle hint – but we don't override error
        }
      }
    }
    [dayInput, monthInput, yearInput].forEach(input => {
      input.addEventListener('blur', checkAgeHint);
    });

    console.log('Popshot signup · 18+ enforced · unique usernames');
  })();
</script>

</body>
</html>
