<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
  <title>Popshot · sign up & log in</title>
  <!-- Fonts & Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    }

    body {
      min-height: 100vh;
      background: #0b0b0f;
      background-image: radial-gradient(circle at 20% 30%, #1a1a2e 0%, #0b0b0f 70%);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      margin: 0;
    }

    /* Main card – glassmorphism, neon edge */
    .popshot-card {
      max-width: 440px;
      width: 100%;
      background: rgba(18, 18, 30, 0.75);
      backdrop-filter: blur(16px) saturate(180%);
      -webkit-backdrop-filter: blur(16px) saturate(180%);
      border-radius: 48px;
      padding: 2rem 1.8rem 2.2rem;
      border: 1px solid rgba(255, 70, 120, 0.25);
      box-shadow: 0 30px 60px rgba(0, 0, 0, 0.8), 0 0 0 1px rgba(255, 70, 120, 0.1) inset, 0 0 30px rgba(255, 70, 120, 0.1);
      transition: all 0.25s ease;
    }

    /* Brand header – Popshot */
    .brand {
      text-align: center;
      margin-bottom: 1.8rem;
    }

    .brand .logo {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 2.4rem;
      font-weight: 800;
      letter-spacing: -1px;
      color: #fff;
      text-shadow: 0 0 20px rgba(255, 70, 120, 0.5);
    }

    .brand .logo i {
      background: linear-gradient(145deg, #ff3b6f, #ff8a5c);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      font-size: 2.6rem;
      filter: drop-shadow(0 0 12px #ff3b6f66);
    }

    .brand .logo span {
      background: linear-gradient(145deg, #ffffff, #e0e0ff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .brand .tagline {
      color: #9a9abf;
      font-size: 0.9rem;
      letter-spacing: 1px;
      margin-top: 2px;
      font-weight: 400;
      opacity: 0.8;
    }

    /* Toggle tabs – tiktok style pill */
    .toggle-tabs {
      display: flex;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 60px;
      padding: 5px;
      margin-bottom: 2rem;
      border: 1px solid rgba(255, 255, 255, 0.06);
      backdrop-filter: blur(4px);
    }

    .toggle-tabs button {
      flex: 1;
      border: none;
      background: transparent;
      padding: 12px 8px;
      border-radius: 60px;
      font-weight: 700;
      font-size: 0.95rem;
      color: #8e8eb0;
      cursor: pointer;
      transition: 0.25s cubic-bezier(0.2, 0.9, 0.3, 1.1);
      letter-spacing: 0.3px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .toggle-tabs button i {
      font-size: 1rem;
    }

    .toggle-tabs button.active {
      background: rgba(255, 70, 120, 0.2);
      color: white;
      box-shadow: 0 0 20px rgba(255, 70, 120, 0.2);
      border: 1px solid rgba(255, 70, 120, 0.3);
      backdrop-filter: blur(4px);
    }

    .toggle-tabs button:first-child.active {
      border-color: rgba(255, 70, 120, 0.3);
    }

    /* forms */
    .auth-form {
      display: block;
    }

    .auth-form.hidden {
      display: none;
    }

    .form-group {
      margin-bottom: 1.3rem;
    }

    .form-group label {
      display: block;
      font-size: 0.8rem;
      font-weight: 600;
      color: #b0b0d4;
      margin-bottom: 6px;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }

    .form-group label i {
      margin-right: 8px;
      color: #ff5a7c;
      width: 18px;
    }

    .input-wrapper {
      display: flex;
      align-items: center;
      background: rgba(255, 255, 255, 0.04);
      border: 1.5px solid rgba(255, 255, 255, 0.08);
      border-radius: 30px;
      padding: 0 18px;
      transition: all 0.2s;
      backdrop-filter: blur(4px);
    }

    .input-wrapper:focus-within {
      border-color: #ff3b6f;
      box-shadow: 0 0 0 4px rgba(255, 59, 111, 0.15), 0 0 20px rgba(255, 59, 111, 0.05);
      background: rgba(255, 255, 255, 0.06);
    }

    .input-wrapper i {
      color: #7070a0;
      font-size: 1rem;
      width: 24px;
      text-align: center;
      transition: 0.2s;
    }

    .input-wrapper:focus-within i {
      color: #ff5a7c;
    }

    .input-wrapper input {
      width: 100%;
      border: none;
      background: transparent;
      padding: 16px 10px;
      font-size: 1rem;
      outline: none;
      color: #f0f0ff;
      font-weight: 500;
    }

    .input-wrapper input::placeholder {
      color: #6a6a92;
      font-weight: 400;
      font-size: 0.9rem;
    }

    /* options row */
    .form-options {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin: 1.5rem 0 1.8rem;
      font-size: 0.9rem;
      color: #b0b0d4;
    }

    .form-options .remember {
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
    }

    .form-options .remember input[type="checkbox"] {
      accent-color: #ff3b6f;
      width: 18px;
      height: 18px;
      border-radius: 6px;
      border: 1px solid #55557a;
      background: transparent;
    }

    .form-options a {
      color: #ff5a7c;
      text-decoration: none;
      font-weight: 500;
      border-bottom: 1px solid transparent;
      transition: 0.15s;
    }

    .form-options a:hover {
      border-bottom-color: #ff5a7c;
    }

    /* primary CTA – neon pop */
    .btn-primary {
      width: 100%;
      background: linear-gradient(145deg, #ff3b6f, #ff6b4a);
      border: none;
      padding: 16px;
      border-radius: 60px;
      font-weight: 700;
      font-size: 1.05rem;
      color: white;
      cursor: pointer;
      transition: 0.25s;
      box-shadow: 0 8px 28px rgba(255, 59, 111, 0.35);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      letter-spacing: 0.5px;
      text-shadow: 0 1px 4px rgba(0,0,0,0.2);
    }

    .btn-primary:hover {
      transform: scale(1.02);
      box-shadow: 0 12px 36px rgba(255, 59, 111, 0.5);
      background: linear-gradient(145deg, #ff2a5e, #ff5a3a);
    }

    .btn-primary:active {
      transform: scale(0.96);
    }

    .btn-primary i {
      font-size: 1.2rem;
    }

    .divider {
      display: flex;
      align-items: center;
      gap: 16px;
      margin: 2rem 0 0.8rem;
      color: #5a5a82;
      font-size: 0.8rem;
      font-weight: 500;
    }

    .divider hr {
      flex: 1;
      border: none;
      border-top: 1.5px solid rgba(255, 255, 255, 0.06);
    }

    .social-login {
      display: flex;
      gap: 10px;
      justify-content: center;
      margin-top: 0.8rem;
    }

    .social-login button {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 40px;
      padding: 12px 14px;
      font-size: 0.9rem;
      font-weight: 600;
      color: #d0d0f0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      cursor: pointer;
      transition: 0.2s;
      flex: 1;
      backdrop-filter: blur(4px);
    }

    .social-login button i {
      font-size: 1.3rem;
    }

    .social-login button:hover {
      background: rgba(255, 255, 255, 0.08);
      border-color: rgba(255, 70, 120, 0.3);
      color: white;
    }

    .auth-footer {
      text-align: center;
      margin-top: 2rem;
      color: #8a8ab0;
      font-size: 0.9rem;
      border-top: 1px solid rgba(255, 255, 255, 0.04);
      padding-top: 1.5rem;
    }

    .auth-footer a {
      color: #ff5a7c;
      font-weight: 600;
      text-decoration: none;
      margin-left: 6px;
    }

    .auth-footer a:hover {
      text-decoration: underline;
    }

    /* micro animations */
    @media (max-width: 460px) {
      .popshot-card { padding: 1.5rem 1.2rem 1.8rem; }
      .brand .logo { font-size: 2rem; }
      .toggle-tabs button { font-size: 0.85rem; padding: 10px 4px; }
      .social-login button { font-size: 0.8rem; }
    }
  </style>
</head>
<body>
  <div class="popshot-card">
    <!-- Brand -->
    <div class="brand">
      <div class="logo">
        <i class="fas fa-bolt"></i>
        <span>popshot</span>
      </div>
      <div class="tagline">⚡ short · bold · viral</div>
    </div>

    <!-- Tabs -->
    <div class="toggle-tabs" role="tablist">
      <button class="active" data-tab="login" id="tab-login"><i class="fas fa-sign-in-alt"></i> Log in</button>
      <button data-tab="signup" id="tab-signup"><i class="fas fa-user-plus"></i> Sign up</button>
    </div>

    <!-- LOGIN FORM -->
    <div id="login-form" class="auth-form">
      <form id="login-form-element" action="#" method="POST">
        <div class="form-group">
          <label for="login-email"><i class="fas fa-envelope"></i> Email or username</label>
          <div class="input-wrapper">
            <i class="fas fa-user-circle"></i>
            <input type="text" id="login-email" placeholder="popstar@popshot.com" required>
          </div>
        </div>
        <div class="form-group">
          <label for="login-password"><i class="fas fa-lock"></i> Password</label>
          <div class="input-wrapper">
            <i class="fas fa-key"></i>
            <input type="password" id="login-password" placeholder="••••••••" required>
          </div>
        </div>
        <div class="form-options">
          <label class="remember">
            <input type="checkbox" checked> Keep me in
          </label>
          <a href="#">Forgot?</a>
        </div>
        <button type="submit" class="btn-primary"><i class="fas fa-arrow-right-to-bracket"></i> Log in</button>
        <div class="divider"><hr> or <hr></div>
        <div class="social-login">
          <button type="button"><i class="fab fa-tiktok"></i> TikTok</button>
          <button type="button"><i class="fab fa-google"></i> Google</button>
          <button type="button"><i class="fab fa-apple"></i> Apple</button>
        </div>
      </form>
      <div class="auth-footer">
        No account? <a href="#" id="switch-to-signup">Join Popshot</a>
      </div>
    </div>

    <!-- SIGNUP FORM -->
    <div id="signup-form" class="auth-form hidden">
      <form id="signup-form-element" action="#" method="POST">
        <div class="form-group">
          <label for="signup-username"><i class="fas fa-user"></i> Username</label>
          <div class="input-wrapper">
            <i class="fas fa-at"></i>
            <input type="text" id="signup-username" placeholder="viral_creator" required>
          </div>
        </div>
        <div class="form-group">
          <label for="signup-email"><i class="fas fa-envelope"></i> Email</label>
          <div class="input-wrapper">
            <i class="fas fa-envelope"></i>
            <input type="email" id="signup-email" placeholder="you@popshot.com" required>
          </div>
        </div>
        <div class="form-group">
          <label for="signup-password"><i class="fas fa-lock"></i> Password</label>
          <div class="input-wrapper">
            <i class="fas fa-key"></i>
            <input type="password" id="signup-password" placeholder="min 8 characters" required>
          </div>
        </div>
        <div class="form-group">
          <label for="signup-confirm"><i class="fas fa-check-circle"></i> Confirm</label>
          <div class="input-wrapper">
            <i class="fas fa-shield-alt"></i>
            <input type="password" id="signup-confirm" placeholder="confirm password" required>
          </div>
        </div>
        <div class="form-options" style="margin-top: 0.2rem;">
          <label class="remember">
            <input type="checkbox" required> I agree to <a href="#" style="color:#ff5a7c; margin-left: 4px;">Terms</a> &amp; <a href="#" style="color:#ff5a7c; margin-left: 4px;">Privacy</a>
          </label>
        </div>
        <button type="submit" class="btn-primary"><i class="fas fa-user-plus"></i> Create account</button>
        <div class="divider"><hr> or <hr></div>
        <div class="social-login">
          <button type="button"><i class="fab fa-tiktok"></i> TikTok</button>
          <button type="button"><i class="fab fa-google"></i> Google</button>
          <button type="button"><i class="fab fa-apple"></i> Apple</button>
        </div>
      </form>
      <div class="auth-footer">
        Already on Popshot? <a href="#" id="switch-to-login">Log in</a>
      </div>
    </div>
  </div>

  <script>
    (function() {
      "use strict";

      // DOM refs
      const loginForm = document.getElementById('login-form');
      const signupForm = document.getElementById('signup-form');
      const tabLogin = document.getElementById('tab-login');
      const tabSignup = document.getElementById('tab-signup');
      const switchToSignup = document.getElementById('switch-to-signup');
      const switchToLogin = document.getElementById('switch-to-login');

      // form fields
      const loginEmail = document.getElementById('login-email');
      const loginPassword = document.getElementById('login-password');
      const signupUsername = document.getElementById('signup-username');
      const signupEmail = document.getElementById('signup-email');
      const signupPassword = document.getElementById('signup-password');
      const signupConfirm = document.getElementById('signup-confirm');

      // Helper: set active tab
      function setActiveTab(tab) {
        tabLogin.classList.remove('active');
        tabSignup.classList.remove('active');
        if (tab === 'login') {
          tabLogin.classList.add('active');
          loginForm.classList.remove('hidden');
          signupForm.classList.add('hidden');
        } else {
          tabSignup.classList.add('active');
          signupForm.classList.remove('hidden');
          loginForm.classList.add('hidden');
        }
        // reset border glow on inputs
        document.querySelectorAll('.input-wrapper').forEach(w => w.style.borderColor = 'rgba(255,255,255,0.08)');
      }

      // Tab click handlers
      tabLogin.addEventListener('click', function(e) {
        e.preventDefault();
        setActiveTab('login');
      });

      tabSignup.addEventListener('click', function(e) {
        e.preventDefault();
        setActiveTab('signup');
      });

      // Switch links
      switchToSignup.addEventListener('click', function(e) {
        e.preventDefault();
        setActiveTab('signup');
      });

      switchToLogin.addEventListener('click', function(e) {
        e.preventDefault();
        setActiveTab('login');
      });

      // ---------- DEMO form feedback ----------
      function showPopshotMessage(msg) {
        // Use a subtle alert – but styled with Popshot vibe
        alert('⚡ ' + msg);
      }

      // Login handler
      document.getElementById('login-form-element').addEventListener('submit', function(e) {
        e.preventDefault();
        const email = loginEmail.value.trim();
        const pass = loginPassword.value.trim();

        if (!email || !pass) {
          showPopshotMessage('Please fill in both fields.');
          return;
        }
        showPopshotMessage('Welcome back, ' + email.split('@')[0] + '! 🎬 (demo login)');
      });

      // Signup handler
      document.getElementById('signup-form-element').addEventListener('submit', function(e) {
        e.preventDefault();
        const username = signupUsername.value.trim();
        const email = signupEmail.value.trim();
        const password = signupPassword.value.trim();
        const confirm = signupConfirm.value.trim();

        if (!username || !email || !password || !confirm) {
          showPopshotMessage('All fields are required.');
          return;
        }
        if (password.length < 8) {
          showPopshotMessage('Password must be at least 8 characters.');
          return;
        }
        if (password !== confirm) {
          showPopshotMessage('Passwords do not match.');
          return;
        }
        showPopshotMessage('Account created for ' + username + '! 🚀 (demo)');
        // optionally switch to login:
        // setActiveTab('login');
      });

      // Social buttons demo
      document.querySelectorAll('.social-login button').forEach(btn => {
        btn.addEventListener('click', function() {
          const provider = this.innerText.trim();
          showPopshotMessage(provider + ' sign-in demo (no backend)');
        });
      });

      // Forgot password link
      document.querySelector('.form-options a[href="#"]')?.addEventListener('click', function(e) {
        e.preventDefault();
        showPopshotMessage('Reset link sent to your email (demo)');
      });

      // Terms & Privacy links inside signup
      document.querySelectorAll('#signup-form .form-options a').forEach(link => {
        link.addEventListener('click', function(e) {
          e.preventDefault();
          showPopshotMessage('📄 ' + this.innerText + ' page (demo)');
        });
      });

      // default: login active
      setActiveTab('login');
    })();
  </script>
</body>
</html>
